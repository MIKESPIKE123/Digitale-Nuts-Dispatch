<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vaststellingen Management Systeem</title>
    
    <!-- Antwerp Core Branding CSS -->
    <link rel="stylesheet" href="https://cdn.antwerpen.be/core_branding_scss/7.0.2/main.min.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <!-- Navigation -->
    <header class="a-header">
        <div class="m-header">
            <div class="m-header__content">
                <div class="m-header__left">
                    <h1 class="h2">🏗️ Vaststellingen Management</h1>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Navigation -->
    <nav class="navigation">
        <button class="nav-btn active" onclick="showSection('dashboard')">📊 Dashboard</button>
        <button class="nav-btn" onclick="showSection('inspection')">📝 Vaststelling</button>
        <button class="nav-btn" onclick="showSection('management')">⚙️ Beheer</button>
        <button class="nav-btn" onclick="showSection('archive')">📁 Archief</button>
        <button class="nav-btn" onclick="showSection('export')">📤 Export</button>
    </nav>

    <!-- Main Content Area -->
    <main class="main-content">
        <!-- Dashboard Section -->
        <section id="dashboard" class="section active">
            <div class="card">
                <h2>📊 Dashboard Overzicht</h2>
                <div class="stats-grid">
                    <div class="stat-card">
                        <h3>Totaal Vaststellingen</h3>
                        <div class="stat-number" id="totalInspections">0</div>
                    </div>
                    <div class="stat-card">
                        <h3>Actieve Vaststelleers</h3>
                        <div class="stat-number" id="activeSupervisors">0</div>
                    </div>
                    <div class="stat-card">
                        <h3>Actieve Utilities</h3>
                        <div class="stat-number" id="activeUtilities">0</div>
                    </div>
                    <div class="stat-card">
                        <h3>Actieve Postcodes</h3>
                        <div class="stat-number" id="activePostcodes">0</div>
                    </div>
                </div>
                
                <div class="card">
                    <h3>Recente Activiteit</h3>
                    <div id="recentActivity">
                        <!-- Wordt gevuld door JavaScript -->
                    </div>
                </div>
            </div>
        </section>

        <!-- Inspection Form Section -->
        <section id="inspection" class="section">
            <div class="card">
                <h2>📝 Nieuwe Vaststelling</h2>
                
                <form id="inspectionForm" class="inspection-form">
                    <div class="m-accordion">
                        <!-- Basis Informatie -->
                        <div class="m-accordion__tab">
                            <button class="m-accordion__header" type="button" aria-expanded="true">
                                📋 Basis Informatie
                            </button>
                            <div class="m-accordion__content" style="display: block;">
                                <div class="form-content">
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label for="inspectionType">Type Werkzaamheden:</label>
                                            <select id="inspectionType" name="type" required>
                                                <option value="" disabled selected>Kies het type</option>
                                            </select>
                                        </div>
                                        
                                        <div class="form-group">
                                            <label for="inspectionNuts">NUTS (Nutsmaatschappij):</label>
                                            <select id="inspectionNuts" name="nuts" required>
                                                <option value="" disabled selected>Eerst type kiezen</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="form-row">
                                        <div class="form-group">
                                            <label for="inspectionPostcode">Postcode:</label>
                                            <select id="inspectionPostcode" name="postcode" required>
                                                <option value="" disabled selected>Kies postcode</option>
                                            </select>
                                        </div>
                                        
                                        <div class="form-group">
                                            <label for="inspectionSupervisor">Vaststeller:</label>
                                            <select id="inspectionSupervisor" name="supervisor" required>
                                                <option value="" disabled selected>Kies vaststeller</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="form-row">
                                        <div class="form-group">
                                            <label for="inspectionAddress">Adres:</label>
                                            <input type="text" id="inspectionAddress" name="address" placeholder="Straat en huisnummer">
                                        </div>
                                        
                                        <div class="form-group">
                                            <label for="workType">Werksoort:</label>
                                            <select id="workType" name="work_type">
                                                <option value="" disabled selected>Kies werksoort</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Planning & Tijden -->
                        <div class="m-accordion__tab">
                            <button class="m-accordion__header" type="button" aria-expanded="false">
                                ⏰ Planning & Tijden
                            </button>
                            <div class="m-accordion__content">
                                <div class="form-content">
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label for="inspectionStartDate">Geplande Start:</label>
                                            <input type="date" id="inspectionStartDate" name="start_date" required>
                                        </div>
                                        
                                        <div class="form-group">
                                <div class="m-accordion__content">
                                    <div class="u-margin-xs">teem</title>
    <!-- Antwerp Core Branding CSS -->
    <link rel="stylesheet" href="https://cdn.antwerpen.be/core_branding_scss/7.0.2/main.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="css/styles.css">
</head>
<body class="a-body">
    <div class="container">
        <header class="header">
            <h1>🔧 Vaststellingen Management Systeem</h1>
            <p>Centraal beheer voor nutsmaatschappijen en vaststellingen</p>
        </header>

        <nav class="navigation">
            <div class="nav-buttons">
                <button class="nav-btn active" onclick="showSection('dashboard')">📊 Dashboard</button>
                <button class="nav-btn" onclick="showSection('inspection')">📝 Nieuwe Vaststelling</button>
                <button class="nav-btn" onclick="showSection('management')">⚙️ Databeheer</button>
                <button class="nav-btn" onclick="showSection('archive')">📁 Archief</button>
                <button class="nav-btn" onclick="showSection('export')">📤 Export</button>
            </div>
        </nav>

        <!-- Dashboard Section -->
        <section id="dashboard" class="section active">
            <div class="card">
                <h2>📊 Dashboard</h2>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-number" id="totalInspections">0</div>
                        <div class="stat-label">Totaal Vaststellingen</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number" id="activeSupervisors">0</div>
                        <div class="stat-label">Actieve Vastellers</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number" id="activeUtilities">0</div>
                        <div class="stat-label">Nutsmaatschappijen</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number" id="activePostcodes">0</div>
                        <div class="stat-label">Postcodes</div>
                    </div>
                </div>
                
                <div class="alert alert-info">
                    <strong>ℹ️ Systeem Status:</strong> 
                    <span id="systemStatus">Configuratie wordt geladen...</span>
                </div>
                
                <div class="card">
                    <h3>📈 Recente Activiteit</h3>
                    <div id="recentActivity">
                        <p>Geen recente activiteit</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Inspection Form Section -->
        <section id="inspection" class="section">
            <div class="card">
                <h2>📝 Nieuwe Vaststelling</h2>
                <form id="inspectionForm">
                    
                    <div class="u-margin">
                        <div class="m-accordion">
                            
                            <!-- Basis Informatie -->
                            <div class="m-accordion__tab">
                                <button class="m-accordion__header" type="button" aria-expanded="true">
                                    📋 Basis Informatie
                                </button>
                                <div class="m-accordion__content">
                                    <div class="u-margin-xs">
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="inspectionType">Type nutsmaatschappij:</label>
                                                <select id="inspectionType" name="type" required>
                                                    <option value="" disabled selected>Kies het type</option>
                                                </select>
                                            </div>
                        
                                            <div class="form-group">
                                                <label for="inspectionNuts">NUTS:</label>
                                                <select id="inspectionNuts" name="nuts" required>
                                                    <option value="" disabled selected>Kies NUTS</option>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="inspectionPostcode">Postcode:</label>
                                                <select id="inspectionPostcode" name="postcode" required>
                                                    <option value="" disabled selected>Kies postcode</option>
                                                </select>
                                            </div>
                                            
                                            <div class="form-group">
                                                <label for="inspectionAddress">Adres/Locatie:</label>
                                                <input type="text" id="inspectionAddress" name="address" placeholder="Straat + nummer" required>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Project Details -->
                            <div class="m-accordion__tab">
                                <button class="m-accordion__header" type="button" aria-expanded="false">
                                    🏗️ Project Details
                                </button>
                                <div class="m-accordion__content">
                                    <div class="u-margin-xs">
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="projectName">Projectnaam:</label>
                                                <input type="text" id="projectName" name="project_name" placeholder="Naam van het project">
                                            </div>
                                            
                                            <div class="form-group">
                                                <label for="workType">Soort Werk:</label>
                                                <select id="workType" name="work_type">
                                                    <option value="" disabled selected>Kies werksoort</option>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="inspectionKind">Type Controle:</label>
                                                <select id="inspectionKind" name="inspection_kind" required>
                                                    <option value="" disabled selected>Kies type controle</option>
                                                </select>
                                            </div>
                                            
                                            <div class="form-group">
                                                <label for="priority">Prioriteit:</label>
                                                <select id="priority" name="priority">
                                                    <option value="" disabled selected>Kies prioriteit</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Planning -->
                            <div class="m-accordion__tab">
                                <button class="m-accordion__header" type="button" aria-expanded="false">
                                    📅 Planning
                                </button>
                                <div class="m-accordion__content">
                                    <div class="u-margin-xs">
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="inspectionStartDate">Geplande Start:</label>
                                                <input type="date" id="inspectionStartDate" name="start_date" required>
                                            </div>
                                            
                                            <div class="form-group">
                            <label for="inspectionEndDate">Geplande Einde:</label>
                            <input type="date" id="inspectionEndDate" name="end_date" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="actualStartTime">Werkelijke Start Tijd:</label>
                            <input type="datetime-local" id="actualStartTime" name="actual_start_time">
                        </div>
                        
                        <div class="form-group">
                            <label for="actualEndTime">Werkelijke Eind Tijd:</label>
                            <input type="datetime-local" id="actualEndTime" name="actual_end_time">
                        </div>
                    </div>

                    <!-- Personeel & Contacten -->
                    <h3>👥 Personeel & Contacten</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="inspectionSupervisor">Vaststeller:</label>
                            <select id="inspectionSupervisor" name="supervisor" required>
                                <option value="" disabled selected>Kies vaststeller</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="contactRole">Contactpersoon Rol:</label>
                            <select id="contactRole" name="contact_role" onchange="updateContactPersonsDropdown()">
                                <option value="" disabled selected>Kies rol</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="contactPerson">Contactpersoon:</label>
                            <select id="contactPerson" name="contact_person" onchange="fillContactDetails()">
                                <option value="" disabled selected>Kies eerst een rol</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="contactPhone">Telefoon:</label>
                            <input type="tel" id="contactPhone" name="contact_phone" placeholder="+32 123 45 67 89" readonly>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="contactEmail">Email:</label>
                            <input type="email" id="contactEmail" name="contact_email" placeholder="contact@example.com" readonly>
                        </div>
                        
                        <div class="form-group">
                            <label for="contactCompany">Bedrijf:</label>
                            <input type="text" id="contactCompany" name="contact_company" placeholder="Bedrijfsnaam" readonly>
                        </div>
                    </div>

                    <!-- Omstandigheden -->
                    <h3>🌤️ Omstandigheden</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="weather">Weersomstandigheden:</label>
                            <select id="weather" name="weather">
                                <option value="" disabled selected>Kies weer</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="temperature">Temperatuur (°C):</label>
                            <input type="number" id="temperature" name="temperature" min="-20" max="50" placeholder="20">
                        </div>
                    </div>

                    <!-- Status & Resultaat -->
                    <h3>✅ Status & Resultaat</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="inspectionStatus">Status:</label>
                            <select id="inspectionStatus" name="status" required>
                                <option value="" disabled selected>Kies status</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="inspectionResult">Resultaat:</label>
                            <select id="inspectionResult" name="result">
                                <option value="" disabled selected>Kies resultaat</option>
                            </select>
                        </div>
                    </div>

                    <!-- Opmerkingen -->
                    <h3>📝 Opmerkingen & Details</h3>
                    <div class="form-group">
                        <label for="inspectionNotes">Algemene Opmerkingen:</label>
                        <textarea id="inspectionNotes" name="notes" rows="4" placeholder="Eventuele opmerkingen over de vaststelling..."></textarea>
                    </div>

                    <div class="form-group">
                        <label for="technicalNotes">Technische Bevindingen:</label>
                        <textarea id="technicalNotes" name="technical_notes" rows="4" placeholder="Technische details, afwijkingen, aanbevelingen..."></textarea>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="followUpRequired">Opvolging Vereist:</label>
                            <select id="followUpRequired" name="follow_up_required">
                                <option value="">Geen opvolging</option>
                                <option value="yes">Ja, opvolging nodig</option>
                                <option value="urgent">Ja, urgente opvolging</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="followUpDate">Opvolging Datum:</label>
                            <input type="date" id="followUpDate" name="follow_up_date">
                        </div>
                    </div>

                        </div>
                    </div>
                </div>

                    <div class="btn-group">
                        <button type="submit" class="btn btn-success">💾 Vaststelling Opslaan</button>
                        <button type="button" class="btn btn-primary" onclick="saveAsDraft()">📄 Bewaren als Concept</button>
                        <button type="reset" class="btn btn-warning">🔄 Formulier Wissen</button>
                    </div>
                </form>
            </div>
        </section>

        <!-- Data Management Section -->
        <section id="management" class="section">
            <div class="card">
                <h2>⚙️ Databeheer</h2>
                
                <!-- Supervisors Management -->
                <div class="card">
                    <h3>👥 Vaststellers Beheren</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="newSupervisorName">Nieuwe Vaststeller:</label>
                            <input type="text" id="newSupervisorName" placeholder="Naam van nieuwe vaststeller">
                        </div>
                        <div class="form-group form-button-group">
                            <button type="button" class="btn btn-success" onclick="addNewSupervisor()">➕ Toevoegen</button>
                            <button type="button" class="btn btn-info" onclick="testFunction()" style="margin-left: 10px;">🧪 Test</button>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="searchSupervisors">🔍 Zoek Vaststeller:</label>
                        <input type="text" id="searchSupervisors" placeholder="Zoek op naam..." onkeyup="filterTable('supervisorsTable', this.value)">
                    </div>
                    
                    <div class="table-container">
                        <table class="data-table" id="supervisorsTable">
                            <thead>
                                <tr>
                                    <th>Naam</th>
                                    <th>Status</th>
                                    <th>Acties</th>
                                </tr>
                            </thead>
                            <tbody id="supervisorsTableBody">
                                <!-- Dynamisch gevuld -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Postcodes Management -->
                <div class="card">
                    <h3>📍 Postcodes Beheren</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="newPostcode">Postcode:</label>
                            <input type="text" id="newPostcode" placeholder="2000" maxlength="4">
                        </div>
                        <div class="form-group">
                            <label for="newPostcodeDescription">Beschrijving:</label>
                            <input type="text" id="newPostcodeDescription" placeholder="Antwerpen (Centrum)">
                        </div>
                        <div class="form-group form-button-group">
                            <button type="button" class="btn btn-success" onclick="addNewPostcode()">➕ Toevoegen</button>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="searchPostcodes">🔍 Zoek Postcode:</label>
                        <input type="text" id="searchPostcodes" placeholder="Zoek op code of beschrijving..." onkeyup="filterTable('postcodesTable', this.value)">
                    </div>
                    
                    <div class="table-container">
                        <table class="data-table" id="postcodesTable">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Beschrijving</th>
                                    <th>Status</th>
                                    <th>Acties</th>
                                </tr>
                            </thead>
                            <tbody id="postcodesTableBody">
                                <!-- Dynamisch gevuld -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Utilities Management -->
                <div class="card">
                    <h3>🏢 Nutsmaatschappijen Beheren</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="newUtilityName">Naam:</label>
                            <input type="text" id="newUtilityName" placeholder="FLUVIUS">
                        </div>
                        <div class="form-group">
                            <label for="newUtilityType">Type:</label>
                            <select id="newUtilityType">
                                <option value="">Kies type</option>
                            </select>
                        </div>
                        <div class="form-group form-button-group">
                            <button type="button" class="btn btn-success" onclick="addNewUtility()">➕ Toevoegen</button>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="searchUtilities">🔍 Zoek Nutsmaatschappij:</label>
                        <input type="text" id="searchUtilities" placeholder="Zoek op naam of type..." onkeyup="filterTable('utilitiesTable', this.value)">
                    </div>
                    
                    <div class="table-container">
                        <table class="data-table" id="utilitiesTable">
                            <thead>
                                <tr>
                                    <th>Naam</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th>Acties</th>
                                </tr>
                            </thead>
                            <tbody id="utilitiesTableBody">
                                <!-- Dynamisch gevuld -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Work Types Management -->
                <div class="card">
                    <h3>🔨 Werksoorten Beheren</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="newWorkTypeName">Naam:</label>
                            <input type="text" id="newWorkTypeName" placeholder="Rioolwerken">
                        </div>
                        <div class="form-group">
                            <label for="newWorkTypeDescription">Beschrijving:</label>
                            <input type="text" id="newWorkTypeDescription" placeholder="Beschrijving van werksoort">
                        </div>
                        <div class="form-group form-button-group">
                            <button type="button" class="btn btn-success" onclick="addNewWorkType()">➕ Toevoegen</button>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="searchWorkTypes">🔍 Zoek Werksoort:</label>
                        <input type="text" id="searchWorkTypes" placeholder="Zoek op naam of beschrijving..." onkeyup="filterTable('workTypesTable', this.value)">
                    </div>
                    
                    <div class="table-container">
                        <table class="data-table" id="workTypesTable">
                            <thead>
                                <tr>
                                    <th>Naam</th>
                                    <th>Beschrijving</th>
                                    <th>Status</th>
                                    <th>Acties</th>
                                </tr>
                            </thead>
                            <tbody id="workTypesTableBody">
                                <!-- Dynamisch gevuld -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Inspection Statuses Management -->
                <div class="card">
                    <h3>📊 Statusen Beheren</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="newStatusName">Status Naam:</label>
                            <input type="text" id="newStatusName" placeholder="Nieuw Status">
                        </div>
                        <div class="form-group">
                            <label for="newStatusColor">Kleur:</label>
                            <input type="color" id="newStatusColor" value="#3498db">
                        </div>
                        <div class="form-group form-button-group">
                            <button type="button" class="btn btn-success" onclick="addNewStatus()">➕ Toevoegen</button>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="searchStatuses">🔍 Zoek Status:</label>
                        <input type="text" id="searchStatuses" placeholder="Zoek status..." onkeyup="filterTable('statusesTable', this.value)">
                    </div>
                    
                    <div class="table-container">
                        <table class="data-table" id="statusesTable">
                            <thead>
                                <tr>
                                    <th>Naam</th>
                                    <th>Kleur</th>
                                    <th>Status</th>
                                    <th>Acties</th>
                                </tr>
                            </thead>
                            <tbody id="statusesTableBody">
                                <!-- Dynamisch gevuld -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Contact Roles Management -->
                <div class="card">
                    <h3>👤 Contactrollen Beheren</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="newRoleName">Rol Naam:</label>
                            <input type="text" id="newRoleName" placeholder="Nieuwe Rol">
                        </div>
                        <div class="form-group">
                            <label for="newRoleDescription">Beschrijving:</label>
                            <input type="text" id="newRoleDescription" placeholder="Beschrijving van de rol">
                        </div>
                        <div class="form-group form-button-group">
                            <button type="button" class="btn btn-success" onclick="addNewContactRole()">➕ Toevoegen</button>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="searchContactRoles">🔍 Zoek Contactrol:</label>
                        <input type="text" id="searchContactRoles" placeholder="Zoek op naam of beschrijving..." onkeyup="filterTable('contactRolesTable', this.value)">
                    </div>
                    
                    <div class="table-container">
                        <table class="data-table" id="contactRolesTable">
                            <thead>
                                <tr>
                                    <th>Naam</th>
                                    <th>Beschrijving</th>
                                    <th>Status</th>
                                    <th>Acties</th>
                                </tr>
                            </thead>
                            <tbody id="contactRolesTableBody">
                                <!-- Dynamisch gevuld -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Contact Persons Management -->
                <div class="card">
                    <h3>👥 Contactpersonen Beheren</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="newContactName">Naam:</label>
                            <input type="text" id="newContactName" placeholder="Jan Janssen">
                        </div>
                        <div class="form-group">
                            <label for="newContactPhone">Telefoon:</label>
                            <input type="tel" id="newContactPhone" placeholder="+32 123 456 789">
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="newContactEmail">Email:</label>
                            <input type="email" id="newContactEmail" placeholder="jan.janssen@example.com">
                        </div>
                        <div class="form-group">
                            <label for="newContactCompany">Bedrijf:</label>
                            <input type="text" id="newContactCompany" placeholder="Bouwbedrijf Janssen">
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="newContactRole">Rol:</label>
                            <select id="newContactRole">
                                <option value="">Kies rol</option>
                            </select>
                        </div>
                        <div class="form-group form-button-group">
                            <button type="button" class="btn btn-success" onclick="addNewContactPerson()">➕ Toevoegen</button>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="searchContactPersons">🔍 Zoek Contactpersoon:</label>
                        <input type="text" id="searchContactPersons" placeholder="Zoek op naam, bedrijf of rol..." onkeyup="filterTable('contactPersonsTable', this.value)">
                    </div>
                    
                    <div class="table-container">
                        <table class="data-table" id="contactPersonsTable">
                            <thead>
                                <tr>
                                    <th>Naam</th>
                                    <th>Telefoon</th>
                                    <th>Email</th>
                                    <th>Bedrijf</th>
                                    <th>Rol</th>
                                    <th>Status</th>
                                    <th>Acties</th>
                                </tr>
                            </thead>
                            <tbody id="contactPersonsTableBody">
                                <!-- Dynamisch gevuld -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="btn-group">
                    <button type="button" class="btn btn-warning" onclick="validateConfiguration()">🔍 Configuratie Valideren</button>
                    <button type="button" class="btn btn-danger" onclick="resetConfiguration()">🔄 Reset naar Standaard</button>
                </div>
            </div>
        </section>

        <!-- Archive Section -->
        <section id="archive" class="section">
            <div class="card">
                <h2>📁 Archief Vaststellingen</h2>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="archiveStartDate">Van datum:</label>
                        <input type="date" id="archiveStartDate">
                    </div>
                    <div class="form-group">
                        <label for="archiveEndDate">Tot datum:</label>
                        <input type="date" id="archiveEndDate">
                    </div>
                    <div class="form-group form-button-group">
                        <button type="button" class="btn btn-primary" onclick="filterArchive()">🔍 Filter</button>
                    </div>
                </div>

                <div class="table-container">
                    <table class="data-table" id="archiveTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Datum</th>
                                <th>Type</th>
                                <th>NUTS</th>
                                <th>Postcode</th>
                                <th>Adres</th>
                                <th>Vaststeller</th>
                                <th>Status</th>
                                <th>Resultaat</th>
                                <th>Prioriteit</th>
                                <th>Acties</th>
                            </tr>
                        </thead>
                        <tbody id="archiveTableBody">
                            <!-- Dynamisch gevuld -->
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <!-- Export Section -->
        <section id="export" class="section">
            <div class="card">
                <h2>📤 Export & Rapportage</h2>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="exportStartDate">Van datum:</label>
                        <input type="date" id="exportStartDate">
                    </div>
                    <div class="form-group">
                        <label for="exportEndDate">Tot datum:</label>
                        <input type="date" id="exportEndDate">
                    </div>
                </div>

                <div class="btn-group">
                    <button type="button" class="btn btn-success" onclick="exportToCSV()">📊 Export naar CSV</button>
                    <button type="button" class="btn btn-primary" onclick="exportConfiguration()">⚙️ Export Configuratie</button>
                    <button type="button" class="btn btn-warning" onclick="generateReport()">📋 Genereer Rapport</button>
                </div>

                <div id="exportResults" class="card hidden">
                    <h3>📈 Export Resultaten</h3>
                    <div id="exportContent"></div>
                </div>
            </div>
        </section>
    </div>

    <!-- Scripts -->
    <script src="js/dataManager.js"></script>
    <script src="js/app.js"></script>
</body>
</html>
