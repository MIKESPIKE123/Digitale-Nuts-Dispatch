{
    "name": "vaststellingen-management-system",
    "version": "1.0.0",
    "description": "Web-based vaststellingen management system for utility companies",
    "main": "index.html",
    "scripts": {
        "start": "http-server . -p 3000 -c-1 --cors",
        "dev": "http-server . -p 8080 -c-1 --cors -o",
        "serve": "python -m http.server 8080",
        "debug": "http-server . -p 3000 -c-1 --cors --silent"
    },
    "devDependencies": {
        "http-server": "^14.1.1"
    },
    "keywords": [
        "vaststellingen",
        "utilities",
        "inspection",
        "management",
        "web-app"
    ],
    "author": "Digipolis Antwerp",
    "license": "MIT"
}