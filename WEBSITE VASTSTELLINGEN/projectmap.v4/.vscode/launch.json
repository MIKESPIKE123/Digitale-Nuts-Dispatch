{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "🚀 Debug Vaststellingen (Veilig)",
            "file": "${workspaceFolder}/index.html",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "breakOnLoad": false,
            "userDataDir": "${workspaceFolder}/.vscode/chrome-debug-profile",
            "runtimeArgs": [
                "--allow-file-access-from-files"
                // ❌ --disable-web-security WEGGELATEN voor veiligheid
            ]
        },
        {
            "type": "chrome",
            "request": "launch", 
            "name": "🌐 Debug met Live Server (AANBEVOLEN)",
            "url": "http://127.0.0.1:5500/index.html",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true
            // ✅ Geen security flags nodig - gebruikt HTTP server
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "🔧 Debug met HTTP Server", 
            "url": "http://localhost:8080/index.html",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "preLaunchTask": "Start HTTP Server"
        }
    ]
}
