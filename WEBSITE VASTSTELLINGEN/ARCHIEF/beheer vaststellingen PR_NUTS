<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Beheer Vaststellers, Postcodes, Types en Nutsmaatschappijen</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@1/css/pico.min.css">
  <style>
    body {
      font-family: 'Antwerpen', sans-serif;
      margin: 20px;
      background-color: #f4f4f9;
    }
    nav.container-fluid {
      background-color: #004080;
      color: white;
    }
    nav.container-fluid ul {
      display: flex;
      justify-content: space-between;
      list-style-type: none;
      padding: 0;
      margin: 0;
    }
    nav.container-fluid ul li {
      padding: 10px 20px;
    }
    nav.container-fluid ul li a {
      color: white;
      text-decoration: none;
    }
    form, section {
      background: #fff;
      padding: 20px;
      border-radius: 5px;
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
      margin-bottom: 20px;
    }
    .button-group {
      display: inline-flex;
      gap: 10px;
    }
    .small-button {
      font-size: 0.8rem;
      padding: 5px 10px;
    }
    .menu-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 10px;
      margin-bottom: 30px;
    }
    .menu-grid a {
      padding: 10px;
      background-color: #004080;
      color: white;
      text-align: center;
      border-radius: 8px;
      text-decoration: none;
    }
    .menu-grid a:hover {
      background-color: #003366;
    }
  </style>
</head>
<body>
  <nav class="container-fluid">
    <ul>
      <li><strong>stad Antwerpen</strong></li>
    </ul>
  </nav>

<main class="container">
  <h1>Hoofdmenu Beheer</h1>
  <div class="menu-grid">
    <a href="#vaststellers">Vaststellers beheren</a>
    <a href="#postcodes">Postcodes beheren</a>
    <a href="#types">Types Nutsmaatschappijen beheren</a>
    <a href="#nuts">Nutsmaatschappijen beheren</a>
  </div>

  <h1 id="vaststellers">Beheer Vaststellers</h1>

  <section>
    <h2>Huidige Vaststellers</h2>
    <ul id="vaststellers-list"></ul>
  </section>

  <form id="add-form">
    <h2>Nieuwe Vaststeller Toevoegen</h2>
    <label for="new-name">Naam:</label>
    <input type="text" id="new-name" required>
    <button type="submit">Toevoegen</button>
  </form>

  <h1 id="postcodes">Beheer Postcodes</h1>

  <section>
    <h2>Huidige Postcodes</h2>
    <ul id="postcodes-list"></ul>
  </section>

  <form id="add-postcode-form">
    <h2>Nieuwe Postcode Toevoegen</h2>
    <label for="new-postcode">Postcode + Beschrijving:</label>
    <input type="text" id="new-postcode" required>
    <button type="submit">Toevoegen</button>
  </form>

  <h1 id="types">Beheer Types Nutsmaatschappijen</h1>

  <section>
    <h2>Huidige Types</h2>
    <ul id="types-list"></ul>
  </section>

  <form id="add-type-form">
    <h2>Nieuw Type Toevoegen</h2>
    <label for="new-type">Type:</label>
    <input type="text" id="new-type" required>
    <button type="submit">Toevoegen</button>
  </form>

  <h1 id="nuts">Beheer Nutsmaatschappijen</h1>

  <section>
    <h2>Huidige Nutsmaatschappijen</h2>
    <ul id="nuts-list"></ul>
  </section>

  <form id="add-nuts-form">
    <h2>Nieuwe Nutsmaatschappij Toevoegen</h2>
    <label for="new-nuts">Naam Nutsmaatschappij:</label>
    <input type="text" id="new-nuts" required>
    <button type="submit">Toevoegen</button>
  </form>
</main>

<script>
// Je bestaande script blijft hier staan
</script>

</body>
</html>
