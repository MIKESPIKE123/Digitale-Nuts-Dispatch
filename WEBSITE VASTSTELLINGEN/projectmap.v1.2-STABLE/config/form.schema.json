{
  "blocks": [
    "blok1_meta",
    "blok2_actor", 
    "blok3_observations",
    "blok4_calculations",
    "blok5_relations"
  ],
  "fields": {
    "gipod_number": {
      "id": "gipod_number",
      "label": "GIPOD Nummer",
      "type": "text",
      "block": "blok1_meta",
      "pattern": "\\d{8}",
      "placeholder": "8-cijferig nummer",
      "required": false
    },
    "inspection_date": {
      "id": "inspection_date",
      "label": "Datum van Vaststelling",
      "type": "date",
      "block": "blok1_meta",
      "required": true,
      "default": "today"
    },
    "description": {
      "id": "description",
      "label": "Beschrijving (Adres voor Google Maps)",
      "type": "textarea",
      "block": "blok1_meta",
      "rows": 3,
      "required": true,
      "placeholder": "Vul hier de beschrijving in"
    },
    "use_gps": {
      "id": "use_gps",
      "label": "Gebruik GPS locatie van dit apparaat",
      "type": "checkbox",
      "block": "blok1_meta",
      "default": false
    },
    "gps_latitude": {
      "id": "gps_latitude",
      "label": "Latitude",
      "type": "text",
      "block": "blok1_meta",
      "readonly": true,
      "showIf": { "any": [{ "field": "use_gps", "equals": true }] }
    },
    "gps_longitude": {
      "id": "gps_longitude",
      "label": "Longitude", 
      "type": "text",
      "block": "blok1_meta",
      "readonly": true,
      "showIf": { "any": [{ "field": "use_gps", "equals": true }] }
    },
    "gps_accuracy": {
      "id": "gps_accuracy",
      "label": "Nauwkeurigheid",
      "type": "text",
      "block": "blok1_meta", 
      "readonly": true,
      "showIf": { "any": [{ "field": "use_gps", "equals": true }] }
    },
    "utility_company": {
      "id": "utility_company",
      "label": "NUTS",
      "type": "select",
      "block": "blok2_actor",
      "required": true,
      "options": "nuts_companies"
    },
    "utility_type": {
      "id": "utility_type", 
      "label": "Type nutsmaatschappij",
      "type": "select",
      "block": "blok2_actor",
      "required": true,
      "options": "utility_types"
    },
    "postcode": {
      "id": "postcode",
      "label": "Postcode",
      "type": "select",
      "block": "blok2_actor",
      "required": true,
      "options": "postcodes"
    },
    "supervisor": {
      "id": "supervisor",
      "label": "Vaststeller (naam)",
      "type": "select",
      "block": "blok2_actor",
      "required": true,
      "options": "supervisors"
    },
    "start_date": {
      "id": "start_date",
      "label": "Geplande Start",
      "type": "date",
      "block": "blok2_actor",
      "required": true
    },
    "end_date": {
      "id": "end_date",
      "label": "Geplande Einde",
      "type": "date", 
      "block": "blok2_actor",
      "required": true
    },
    "finding_type": {
      "id": "finding_type",
      "label": "Vaststelling ter Plaatse (maar 1 keuze mogelijk)",
      "type": "radio",
      "block": "blok3_observations",
      "required": true,
      "options": [
        { "value": "geen_signalisatie", "label": "GEEN SIGNALISATIE GEEN WERKEN (Alleen foto's trekken)" },
        { "value": "signalisatie_geen_werken", "label": "SIGNALISATIE ZICHTBAAR GEEN WERKEN (Alleen foto's trekken)" },
        { "value": "signalisatie_werken_uitvoering", "label": "SIGNALISATIE ZICHTBAAR WERKEN IN UITVOERING (Vaststelling verder invullen en foto's trekken)" },
        { "value": "signalisatie_werken_niet_uitvoering", "label": "SIGNALISATIE ZICHTBAAR WERKEN NIET IN UITVOERING (werfzone) (Vaststelling verder invullen en foto's trekken)" },
        { "value": "werken_uitgevoerd", "label": "WERKEN ZIJN UITGEVOERD (Hieronder verder invullen en foto's trekken)" }
      ]
    },
    "executed": {
      "id": "executed",
      "label": "Zijn de werken uitgevoerd?",
      "type": "radio",
      "block": "blok3_observations",
      "options": [
        { "value": "ja", "label": "Ja" },
        { "value": "neen", "label": "Neen" }
      ],
      "showIf": { "all": [{ "field": "finding_type", "in": ["signalisatie_werken_uitvoering", "signalisatie_werken_niet_uitvoering", "werken_uitgevoerd"] }] }
    },
    "visible": {
      "id": "visible",
      "label": "Werfafbakening - Zichtbaar OK?",
      "type": "radio", 
      "block": "blok3_observations",
      "required": true,
      "options": [
        { "value": "ja", "label": "Ja" },
        { "value": "neen", "label": "Neen (niet OK)" }
      ],
      "showIf": { "all": [{ "field": "finding_type", "in": ["signalisatie_werken_uitvoering", "signalisatie_werken_niet_uitvoering", "werken_uitgevoerd"] }] }
    },
    "safety_remarks": {
      "id": "safety_remarks",
      "label": "Opmerkingen Veiligheid",
      "type": "checkbox-group",
      "block": "blok3_observations",
      "options": "safety_remarks",
      "showIf": { "all": [{ "field": "visible", "equals": "neen" }] }
    },
    "material_present": {
      "id": "material_present",
      "label": "Achtergebleven Materiaal/Materieel?",
      "type": "radio",
      "block": "blok3_observations",
      "required": true,
      "options": [
        { "value": "neen", "label": "Neen, geen materiaal achtergelaten" },
        { "value": "ja", "label": "Ja, er is materiaal achtergelaten" }
      ],
      "showIf": { "all": [{ "field": "finding_type", "in": ["signalisatie_werken_uitvoering", "signalisatie_werken_niet_uitvoering", "werken_uitgevoerd"] }] }
    },
    "material_types": {
      "id": "material_types",
      "label": "Welk type materiaal?",
      "type": "checkbox-group",
      "block": "blok3_observations",
      "options": "material_types",
      "showIf": { "all": [{ "field": "material_present", "equals": "ja" }] }
    },
    "defects_present": {
      "id": "defects_present",
      "label": "Vastgestelde Gebreken?",
      "type": "radio",
      "block": "blok3_observations",
      "required": true,
      "options": [
        { "value": "neen", "label": "Neen, geen gebreken vastgesteld" },
        { "value": "ja", "label": "Ja, er zijn gebreken vastgesteld" }
      ],
      "showIf": { "all": [{ "field": "finding_type", "in": ["signalisatie_werken_uitvoering", "signalisatie_werken_niet_uitvoering", "werken_uitgevoerd"] }] }
    },
    "defects_types": {
      "id": "defects_types",
      "label": "Welke gebreken?",
      "type": "checkbox-group", 
      "block": "blok3_observations",
      "options": "defects_list",
      "showIf": { "all": [{ "field": "defects_present", "equals": "ja" }] }
    },
    "repair_assessment": {
      "id": "repair_assessment",
      "label": "Vaststelling Herstelling/bestrating (meerdere mogelijk)",
      "type": "checkbox-group",
      "block": "blok3_observations",
      "options": [
        { "value": "behandeling_zichtbaar", "label": "Behandeling zichtbaar" },
        { "value": "materiaal_afwijkend", "label": "Materiaal wijkt af van omgevend materiaal" },
        { "value": "andere", "label": "Andere (opmerking toevoegen)" }
      ],
      "showIf": { "all": [{ "field": "finding_type", "in": ["signalisatie_werken_uitvoering", "signalisatie_werken_niet_uitvoering", "werken_uitgevoerd"] }] }
    },
    "repair_other_comment": {
      "id": "repair_other_comment",
      "label": "Specificeer andere opmerking",
      "type": "textarea",
      "block": "blok3_observations",
      "rows": 3,
      "placeholder": "Beschrijf de andere bevinding...",
      "showIf": { "all": [{ "field": "repair_assessment", "contains": "andere" }] }
    },
    "urgent_action": {
      "id": "urgent_action",
      "label": "Dringende Actie Nodig?",
      "type": "radio",
      "block": "blok3_observations",
      "required": true,
      "options": [
        { "value": "ja", "label": "JA" },
        { "value": "nee", "label": "NEE" }
      ],
      "showIf": { "all": [{ "field": "finding_type", "in": ["signalisatie_werken_uitvoering", "signalisatie_werken_niet_uitvoering", "werken_uitgevoerd"] }] }
    },
    "additional_findings": {
      "id": "additional_findings",
      "label": "Bijkomende Vaststellingen",
      "type": "radio", 
      "block": "blok4_calculations",
      "options": [
        { "value": "neen", "label": "Neen" },
        { "value": "ja", "label": "Ja - Bijkomende vaststellingen" }
      ],
      "default": "neen"
    },
    "signalization_permit_nr": {
      "id": "signalization_permit_nr",
      "label": "Nr. Signalisatievergunning",
      "type": "text",
      "block": "blok4_calculations",
      "placeholder": "Bijv. GW2025-001224",
      "showIf": { "all": [{ "field": "additional_findings", "equals": "ja" }] }
    },
    "permit_expiry_date": {
      "id": "permit_expiry_date",
      "label": "Vervaldatum Vergunning",
      "type": "date",
      "block": "blok4_calculations",
      "showIf": { "all": [{ "field": "additional_findings", "equals": "ja" }] }
    },
    "violation_start_date": {
      "id": "violation_start_date",
      "label": "Start Overtreding",
      "type": "date",
      "block": "blok4_calculations", 
      "showIf": { "all": [{ "field": "additional_findings", "equals": "ja" }] }
    },
    "contractor_company": {
      "id": "contractor_company",
      "label": "Aannemer",
      "type": "text",
      "block": "blok4_calculations",
      "placeholder": "Bijv. Cas-Vos",
      "showIf": { "all": [{ "field": "additional_findings", "equals": "ja" }] }
    },
    "utility_responsible": {
      "id": "utility_responsible", 
      "label": "Verantwoordelijke Nuts",
      "type": "select",
      "block": "blok4_calculations",
      "options": [
        { "value": "wyre", "label": "Wyre" },
        { "value": "proximus", "label": "Proximus" },
        { "value": "fluvius", "label": "Fluvius" },
        { "value": "waterlink", "label": "Water-link" },
        { "value": "other", "label": "Andere" }
      ],
      "showIf": { "all": [{ "field": "additional_findings", "equals": "ja" }] }
    },
    "daily_rate": {
      "id": "daily_rate",
      "label": "Tarief per m²/dag (€)",
      "type": "number",
      "block": "blok4_calculations",
      "step": "0.01",
      "min": "0",
      "readonly": true,
      "computed": "settings.dailyRate",
      "showIf": { "all": [{ "field": "additional_findings", "equals": "ja" }] }
    },
    "violation_days": {
      "id": "violation_days",
      "label": "Aantal Dagen Overtreding",
      "type": "number",
      "block": "blok4_calculations",
      "min": "1",
      "readonly": true,
      "computed": "sum(locationMeasures.violationDays)",
      "showIf": { "all": [{ "field": "additional_findings", "equals": "ja" }] }
    },
    "total_area": {
      "id": "total_area",
      "label": "Totale Oppervlakte (m²)",
      "type": "number",
      "block": "blok4_calculations",
      "readonly": true,
      "computed": "sum(locationMeasures.area)",
      "showIf": { "all": [{ "field": "additional_findings", "equals": "ja" }] }
    },
    "total_fine": {
      "id": "total_fine",
      "label": "Totaal Retributie (€)",
      "type": "number", 
      "block": "blok4_calculations",
      "readonly": true,
      "computed": "settings.dailyRate * sum(locationMeasures.area) * sum(locationMeasures.violationDays)",
      "showIf": { "all": [{ "field": "additional_findings", "equals": "ja" }] }
    },
    "permitted_area": {
      "id": "permitted_area",
      "label": "Vergunde Oppervlakte (m²)",
      "type": "number",
      "block": "blok4_calculations",
      "step": "0.1",
      "min": "0",
      "placeholder": "Bijv. 150.5",
      "showIf": { "all": [{ "field": "additional_findings", "equals": "ja" }] }
    },
    "actual_area": {
      "id": "actual_area", 
      "label": "Werkelijk Ingenomen Oppervlakte (m²)",
      "type": "number",
      "block": "blok4_calculations",
      "step": "0.1",
      "min": "0",
      "placeholder": "Bijv. 180.2",
      "showIf": { "all": [{ "field": "additional_findings", "equals": "ja" }] }
    },
    "link_related_findings": {
      "id": "link_related_findings",
      "label": "Deze vaststelling is gerelateerd aan andere vaststellingen",
      "type": "checkbox",
      "block": "blok5_relations",
      "default": false
    },
    "related_inspection_ids": {
      "id": "related_inspection_ids",
      "label": "Gerelateerde Vaststelling Nummers",
      "type": "text",
      "block": "blok5_relations",
      "placeholder": "Bijv. VST-2025-001, VST-2025-002",
      "showIf": { "all": [{ "field": "link_related_findings", "equals": true }] }
    },
    "work_reference": {
      "id": "work_reference",
      "label": "Gemeenschappelijke Werk Referentie",
      "type": "text",
      "block": "blok5_relations",
      "placeholder": "Bijv. PROJECT-2025-ANTWERP-001",
      "showIf": { "all": [{ "field": "link_related_findings", "equals": true }] }
    },
    "relation_type": {
      "id": "relation_type",
      "label": "Type Relatie",
      "type": "select",
      "block": "blok5_relations",
      "options": "relation_types",
      "showIf": { "all": [{ "field": "link_related_findings", "equals": true }] }
    },
    "additional_info": {
      "id": "additional_info",
      "label": "Bijkomende Info",
      "type": "textarea",
      "block": "blok5_relations",
      "rows": 4,
      "placeholder": "Eventuele extra opmerkingen..."
    }
  },
  "codelists": {
    "safety_remarks": [
      { "value": "connections", "label": "Huisaansluitingen DWA en RWA maken" },
      { "value": "cyclists", "label": "Doorgangen fietsers voorzien" },
      { "value": "pedestrians", "label": "Doorgangen voetgangers vrijhouden" }
    ],
    "material_types": [
      { "value": "los_materiaal", "label": "Los materiaal achtergelaten" },
      { "value": "signalisatie", "label": "Signalisatie achtergelaten" }
    ],
    "defects_list": [
      { "value": "wegdek_beschadigd", "label": "Wegdek beschadigd" },
      { "value": "onveilige_situatie", "label": "Onveilige situatie" },
      { "value": "signalisatie_ontbreekt", "label": "Signalisatie ontbreekt" },
      { "value": "afwatering_geblokkeerd", "label": "Afwatering geblokkeerd" },
      { "value": "markering_weggevallen", "label": "Markering weggevallen" }
    ],
    "utility_types": [
      { "value": "elektriciteit", "label": "Elektriciteit" },
      { "value": "gas", "label": "Gas" },
      { "value": "water", "label": "Water" },
      { "value": "telecom", "label": "Telecom" },
      { "value": "riolering", "label": "Riolering" },
      { "value": "warmte", "label": "Warmte" }
    ],
    "relation_types": [
      { "value": "same_work", "label": "Zelfde werk/project" },
      { "value": "follow_up", "label": "Opvolging vaststelling" },
      { "value": "correction", "label": "Correctie eerdere vaststelling" },
      { "value": "extension", "label": "Uitbreiding werkzone" },
      { "value": "completion", "label": "Afronding werkzaamheden" }
    ]
  },
  "locationMeasures": {
    "fields": {
      "location_address": {
        "label": "Locatie/Adres",
        "type": "text",
        "placeholder": "Bijv. Arenbergstraat nr 16"
      },
      "location_length": {
        "label": "Lengte (m)",
        "type": "number",
        "step": "0.1",
        "min": "0"
      },
      "location_width": {
        "label": "Breedte (m)",
        "type": "number", 
        "step": "0.1",
        "min": "0"
      },
      "location_area": {
        "label": "Oppervlakte (m²)",
        "type": "number",
        "readonly": true,
        "computed": "location_length * location_width"
      },
      "location_permitted_duration": {
        "label": "Vergunde Doorlooptijd (dagen)",
        "type": "number",
        "min": "1",
        "placeholder": "Bijv. 30"
      },
      "location_extra_duration": {
        "label": "Extra Doorlooptijd (dagen)",
        "type": "number",
        "min": "0", 
        "placeholder": "Bijv. 15"
      },
      "location_violation_days": {
        "label": "Subtotaal Dagen Overtreding",
        "type": "number",
        "readonly": true,
        "computed": "location_permitted_duration + location_extra_duration"
      }
    }
  },
  "settings": {
    "dailyRate": 5.00
  }
}
