{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Live Server",
            "type": "shell",
            "command": "echo",
            "args": ["Live Server should be started manually via VS Code extension"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Start Node Server",
            "type": "shell",
            "command": "npx",
            "args": ["http-server", ".", "-p", "3000", "-c-1"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new"
            },
            "problemMatcher": [],
            "isBackground": true,
            "runOptions": {
                "instanceLimit": 1
            }
        },
        {
            "label": "Start Python Server",
            "type": "shell",
            "command": "python",
            "args": ["-m", "http.server", "8080"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new"
            },
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "Stop Live Server",
            "type": "shell",
            "command": "echo",
            "args": ["Live Server stopped"],
            "group": "build"
        },
        {
            "label": "Stop Node Server",
            "type": "shell",
            "command": "taskkill",
            "args": ["/F", "/IM", "node.exe"],
            "group": "build",
            "windows": {
                "command": "taskkill",
                "args": ["/F", "/IM", "node.exe"]
            },
            "linux": {
                "command": "pkill",
                "args": ["-f", "http-server"]
            },
            "osx": {
                "command": "pkill",
                "args": ["-f", "http-server"]
            }
        }
    ]
}