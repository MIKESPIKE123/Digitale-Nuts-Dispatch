{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "🚀 Vaststellingen App (Direct File)",
            "file": "${workspaceFolder}/projectmap.v4/index.html",
            "webRoot": "${workspaceFolder}/projectmap.v4"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "🌐 Vaststellingen App (localhost:8000)",
            "url": "http://localhost:8000/projectmap.v4/index.html",
            "webRoot": "${workspaceFolder}/projectmap.v4",
            "preLaunchTask": "Start HTTP Server Port 8000"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "🌐 Vaststellingen App (localhost:8080)",
            "url": "http://localhost:8080/projectmap.v4/index.html",
            "webRoot": "${workspaceFolder}/projectmap.v4",
            "preLaunchTask": "Start HTTP Server Port 8080"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "🔍 Debug Vaststellingen (localhost:3000)",
            "url": "http://localhost:3000/projectmap.v4/index.html",
            "webRoot": "${workspaceFolder}/projectmap.v4",
            "sourceMaps": true,
            "preLaunchTask": "Start HTTP Server Port 3000"
        }
    ]
}